# Application
APP_NAME=Finance Dashboard API
APP_VERSION=1.0.0
DEBUG=True

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# First Admin User (auto-created on startup)
FIRST_ADMIN_EMAIL=admin@finance.com
FIRST_ADMIN_PASSWORD=Admin@123
FIRST_ADMIN_USERNAME=admin
